# ──── Server ────
PORT=5000
NODE_ENV=development

# ──── Neon PostgreSQL ────
DB_HOST=your-neon-project-id.us-east-2.aws.neon.tech
DB_PORT=5432
DB_NAME=customer_support_agent
DB_USER=your_neon_db_user
DB_PASSWORD=your_neon_db_password
DB_SSL=true
DATABASE_URL=postgresql://your_neon_db_user:your_neon_db_password@your-neon-project-id.us-east-2.aws.neon.tech:5432/customer_support_agent?sslmode=require

# ──── Groq (Phase 2) ────
GROQ_API_KEY=your_groq_api_key_here

# ──── Hindsight Cloud (Phase 3 — not needed yet) ────
HINDSIGHT_API_KEY=your_hindsight_api_key_here

# ──── Frontend ────
VITE_API_URL=http://localhost:5000/api
